# ─────────────────────────────────────────────────────────────────────────────
# Hawkeye AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-256-bit-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup needed)
DATABASE_URL=sqlite:///./hawkeye_jobs.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://root:password@localhost/hawkeye_ai

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Cloud Sync (optional — leave empty to disable) ───────────────────────────
HAWKEYE_CLOUD_API_KEY=
HAWKEYE_CLOUD_API_URL=https://api.hawkeye-road.com/v1

# ── Upload Limits ─────────────────────────────────────────────────────────────
# Max video file size in bytes (default: 5 GB)
MAX_UPLOAD_BYTES=5368709120
